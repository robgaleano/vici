{
  "name": "vici-monorepo",
  "version": "1.0.0",
  "description": "Running to conquer a new territory",
  "private": true,
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "scripts": {
    "mobile": "pnpm --filter @vici/mobile start",
    "mobile:ios": "pnpm --filter @vici/mobile ios",
    "mobile:android": "pnpm --filter @vici/mobile android",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commit": "czg",
    "commit:help": "czg --help",
    "commit:retry": "czg --retry",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "czg": "^1.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.5.4",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
