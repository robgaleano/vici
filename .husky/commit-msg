#!/usr/bin/env sh

npx --no -- commitlint --edit "$1"
status=$?

if [ "$status" -ne 0 ]; then
	echo ""
	echo "Sugerencia: usa 'git commit' sin '-m' o 'npm run commit' para abrir el flujo interactivo de czg."
	echo "Ejemplos validos: feat(setup): ... | fix(lint): ... | chore(git): ..."
fi

exit "$status"